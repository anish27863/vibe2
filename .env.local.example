# Environment Variables for SmartRoute
# Copy this file to .env.local and fill in your values.

# ===============================================================
# OpenRouteService (ORS) — Free routing API
# Get your free API key at: https://openrouteservice.org/dev/#/signup
# Free tier: 2,000 requests/day | No credit card required
#
# APIs used (all included in the free tier):
#   • Directions API  (v2/directions/{profile})
#   • Isochrones, Matrix, etc.
# ===============================================================
ORS_API_KEY=your_ors_api_key_here

# ===============================================================
# Nominatim (OpenStreetMap) — Free geocoding & place search
# NO API KEY REQUIRED — completely free, no sign-up needed.
# Attribution: "© OpenStreetMap contributors" (shown in map UI)
# ===============================================================
# (nothing to configure — it just works)

# ===============================================================
# Supabase — Free PostgreSQL database + Auth
# Get these from: https://supabase.com → Project → Settings → API
# Free tier: 500 MB database, 50,000 monthly active users
# ===============================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ===============================================================
# App
# ===============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
